{
    "components": {
        "schemas": {
            "file-service_service_file.File": {
                "properties": {
                    "Bucket": {
                        "$ref": "#/components/schemas/file.Bucket"
                    },
                    "FileName": {
                        "type": "string"
                    },
                    "FileSize": {
                        "type": "integer"
                    },
                    "ID": {
                        "type": "integer"
                    },
                    "URL": {
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "file.Bucket": {
                "enum": [
                    "images",
                    "documents"
                ],
                "type": "string",
                "x-enum-varnames": [
                    "BucketImages",
                    "BucketDocuments"
                ]
            },
            "gorouter.ErrorInfo": {
                "properties": {
                    "code": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "gorouter.ErrorResponse": {
                "properties": {
                    "error": {
                        "$ref": "#/components/schemas/gorouter.ErrorInfo"
                    }
                },
                "type": "object"
            }
        }
    },
    "info": {
        "description": "API for uploading files and reading file metadata.",
        "title": "File Service API",
        "version": "1.0"
    },
    "externalDocs": {
        "description": "",
        "url": ""
    },
    "paths": {
        "/files": {
            "get": {
                "description": "Returns metadata for several files.",
                "parameters": [
                    {
                        "description": "File IDs",
                        "in": "query",
                        "name": "id",
                        "required": true,
                        "schema": {
                            "items": {
                                "type": "integer"
                            },
                            "type": "array"
                        },
                        "style": "form"
                    },
                    {
                        "description": "Maximum number of items to return; 0 means no limit",
                        "in": "query",
                        "name": "limit",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "description": "Number of items to skip",
                        "in": "query",
                        "name": "offset",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "items": {
                                        "$ref": "#/components/schemas/file-service_service_file.File"
                                    },
                                    "type": "array"
                                }
                            }
                        },
                        "description": "OK"
                    },
                    "400": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/gorouter.ErrorResponse"
                                }
                            }
                        },
                        "description": "Bad Request"
                    },
                    "500": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/gorouter.ErrorResponse"
                                }
                            }
                        },
                        "description": "Internal Server Error"
                    }
                },
                "summary": "Get files by IDs",
                "tags": [
                    "files"
                ]
            },
            "post": {
                "description": "Uploads one file to object storage and stores its metadata.",
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "title": "File",
                                "type": "file"
                            }
                        },
                        "multipart/form-data": {
                            "schema": {
                                "type": "object"
                            }
                        }
                    },
                    "description": "File to upload",
                    "required": true
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/file-service_service_file.File"
                                }
                            }
                        },
                        "description": "OK"
                    },
                    "400": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/gorouter.ErrorResponse"
                                }
                            }
                        },
                        "description": "Bad Request"
                    },
                    "500": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/gorouter.ErrorResponse"
                                }
                            }
                        },
                        "description": "Internal Server Error"
                    }
                },
                "summary": "Upload file",
                "tags": [
                    "files"
                ]
            }
        },
        "/files/{id}": {
            "get": {
                "description": "Returns file metadata and a URL by file identifier.",
                "parameters": [
                    {
                        "description": "File ID",
                        "in": "path",
                        "name": "id",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/file-service_service_file.File"
                                }
                            }
                        },
                        "description": "OK"
                    },
                    "400": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/gorouter.ErrorResponse"
                                }
                            }
                        },
                        "description": "Bad Request"
                    },
                    "404": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/gorouter.ErrorResponse"
                                }
                            }
                        },
                        "description": "Not Found"
                    },
                    "500": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/gorouter.ErrorResponse"
                                }
                            }
                        },
                        "description": "Internal Server Error"
                    }
                },
                "summary": "Get file by ID",
                "tags": [
                    "files"
                ]
            }
        }
    },
    "openapi": "3.1.0",
    "servers": [
        {
            "url": "/api/file-service"
        }
    ]
}